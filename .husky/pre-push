BUN_BIN="${HOME}/.bun/bin"
if [ ! -d "$BUN_BIN" ]; then
  BUN_BIN=$(ls -d /Users/*/.bun/bin 2>/dev/null | head -1)
fi
export PATH="/usr/bin:/bin:/usr/local/bin:${BUN_BIN}:/opt/homebrew/bin:${PATH}"
export AGENTS_SECRETS_BACKEND="env"  # never trigger macOS keychain dialogs in hook subprocesses

# Skip tests when only non-code files changed (.github/, docs, config files, etc.)
changed=$(git diff --name-only HEAD @{u} 2>/dev/null || true)
if [ -n "$changed" ] && ! echo "$changed" | grep -qE '^src/'; then
  exit 0
fi

# Unit tests only — e2e runs in CI (tests/e2e/ has Docker deps and takes ~2min)
bun test src/
